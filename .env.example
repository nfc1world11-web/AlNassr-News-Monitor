# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=nfc1world11@gmail.com
SMTP_PASSWORD=xriq awgr qzxf hexy
SMTP_FROM=nfc1world11@gmail.com
EMAIL_RECIPIENT=nfc1world11@gmail.com
EMAIL_RECIPIENT_NAME=مراقب النصر
SEND_NO_NEWS_EMAIL=true

# ============================================
# AI/LLM Configuration
# ============================================
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
ANTHROPIC_API_KEY=your-anthropic-api-key
MINIMUM_RELEVANCE_THRESHOLD=7

# ============================================
# Application Configuration
# ============================================
APP_NAME=AlNassr News Monitor
APP_VERSION=1.0.0
TIMEZONE=Asia/Riyadh
CHECK_INTERVAL_MINUTES=5
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# Scheduler Configuration
# ============================================
SCHEDULER_ENABLED=true
SCHEDULER_WORKERS=1

# ============================================
# Web Dashboard Configuration
# ============================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production
DASHBOARD_ENABLED=true

# ============================================
# News Sources Configuration
# ============================================
SOURCES_CONFIG_FILE=config/sources.yaml

# ============================================
# Retry Configuration
# ============================================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# ============================================
# Email Alert Configuration
# ============================================
ERROR_ALERT_ENABLED=true
ERROR_ALERT_THRESHOLD=3
ERROR_ALERT_EMAIL=nfc1world11@gmail.com
